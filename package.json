{
  "name": "commix",
  "displayName": "CommiX",
  "description": "AI-powered commit message generator & coding assistant. AI Edit, Refactor, Explain, and Convert tools, featuring CodeLens, Inline Suggestions, and Diff-based Previews — powered by OpenAI, Gemini, and NVIDIA.",
  "version": "6.2.1",
  "engines": {
    "node": ">=16",
    "vscode": "^1.106.2"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "AI",
    "OpenAI",
    "Azure",
    "Gemini",
    "DeepSeek",
    "Git",
    "Git Commit",
    "Commit Message",
    "Commit Generator",
    "Conventional Commits",
    "Gitmoji",
    "Commit Assistant",
    "Semantic Commit",
    "Auto Commit",
    "Code Review",
    "CommiX"
  ],
  "publisher": "paswans05",
  "repository": "https://github.com/paswans05/commix.git",
  "icon": "assets/images/logo.png",
  "activationEvents": [
    "onCommand:commix"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.commix",
        "icon": {
          "dark": "assets/images/icon.svg",
          "light": "assets/images/icon.svg"
        },
        "title": "CommiX"
      },
      {
        "command": "commix.showAvailableModels",
        "title": "Show Available OpenAI Models"
      },
      {
        "command": "commix.showAvailableNvidiaModels",
        "title": "Show Available NVIDIA Models"
      },
      {
        "command": "commix.showAvailableGeminiModels",
        "title": "Show Available Gemini Models"
      },
      {
        "command": "commix.aiEdit",
        "title": "CommiX: $(edit) AI Edit / Refactor"
      },
      {
        "command": "commix.aiExplain",
        "title": "CommiX: $(output) Explain Code"
      },
      {
        "command": "commix.aiConvert",
        "title": "CommiX: $(sync) Convert Code"
      },
      {
        "command": "commix.aiSnippet",
        "title": "CommiX: $(code) Generate Snippet"
      },
      {
        "command": "commix.aiTest",
        "title": "CommiX: $(beaker) Generate Test"
      },
      {
        "command": "commix.aiDoc",
        "title": "CommiX: $(book) Generate Documentation"
      },
      {
        "command": "commix.aiWorkflow",
        "title": "CommiX: $(list-ordered) Run AI Workflow"
      },
      {
        "command": "commix.saveTemplate",
        "title": "CommiX: $(save) Save as Template"
      },
      {
        "command": "commix.insertTemplate",
        "title": "CommiX: $(layout) Insert Template"
      },
      {
        "command": "commix.preCommitDoc",
        "title": "Doc Generator",
        "icon": {
          "dark": "assets/images/logo-doc.svg",
          "light": "assets/images/logo-doc.svg"
        }
      }
    ],
    "configuration": {
      "properties": {
        "commix.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable CodeLens (AI Edit/Explain icons above functions)"
        },
        "commix.AI_LANGUAGE": {
          "default": "English",
          "description": "Commit message language",
          "enum": [
            "Japanese",
            "Korean",
            "Czech",
            "German",
            "French",
            "Italian",
            "Dutch",
            "Portuguese",
            "Vietnamese",
            "English",
            "Spanish",
            "Swedish",
            "Russian",
            "Bahasa",
            "Polish",
            "Turkish",
            "Thai",
            "Hindi"
          ],
          "enumDescriptions": [
            "にほんご",
            "한국어",
            "česky",
            "Deutsch",
            "française",
            "italiano",
            "Nederlands",
            "português",
            "tiếng Việt",
            "english",
            "español",
            "Svenska",
            "русский",
            "bahasa",
            "Polski",
            "Turkish",
            "ไทย",
            "हिन्दी"
          ],
          "type": "string"
        },
        "commix.API_VERSION": {
          "default": "",
          "description": "API VERSION",
          "type": "string"
        },
        "commix.OPENAI_API_KEY": {
          "default": "",
          "description": "OpenAI API Key",
          "type": "string"
        },
        "commix.OPENAI_BASE_URL": {
          "default": "",
          "description": "OpenAI BASE URL",
          "type": "string"
        },
        "commix.OPENAI_MODEL": {
          "default": "gpt-4o",
          "description": "OpenAI MODEL, you can select a model from the list by running the 'Show Available OpenAI Models' command",
          "type": "string"
        },
        "commix.PROMPT_SNIPPET": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Snippet Generator"
        },
        "commix.PROMPT_TEST": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Test Generator"
        },
        "commix.PROMPT_DOC": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Documentation Builder"
        },
        "commix.SYSTEM_PROMPT": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for generating commit messages"
        },
        "commix.OPENAI_TEMPERATURE": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "OpenAI temperature setting (0-2). Higher values make output more random, lower values more deterministic."
        },
        "commix.AI_PROVIDER": {
          "type": "string",
          "default": "openai",
          "description": "AI Provider to use (OpenAI , Gemini and NVIDIA)",
          "enum": [
            "openai",
            "gemini",
            "nvidia",
            "groq",
            "ollama"
          ]
        },
        "commix.GEMINI_API_KEY": {
          "type": "string",
          "default": "",
          "description": "Gemini API Key"
        },
        "commix.GEMINI_MODEL": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Gemini Model to use",
          "enum": [
            "gemini-3.5-flash",
            "gemini-3.1-pro",
            "gemini-3.1-flash-lite",
            "gemini-2.5-flash",
            "gemini-2.5-pro",
            "gemini-2.0-flash",
            "gemini-1.5-flash-latest"
          ],
          "enumDescriptions": [
            "Gemini 3.5 Flash (Latest fast, high-performance model)",
            "Gemini 3.1 Pro (Latest complex reasoning model)",
            "Gemini 3.1 Flash-Lite (Latest highly-efficient model)",
            "Gemini 2.5 Flash (Current stable fast model)",
            "Gemini 2.5 Pro (Current stable high-intelligence model)",
            "Gemini 2.0 Flash (Stable 2.0 series)",
            "Gemini 1.5 Flash Latest (Latest 1.5 series)"
          ]
        },
        "commix.GEMINI_TEMPERATURE": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Gemini temperature setting (0-2). Controls randomness."
        },
        "commix.NVIDIA_API_KEY": {
          "type": "string",
          "default": "",
          "description": "NVIDIA API Key. Get your key from: https://build.nvidia.com → Sign in → API Keys → Create Key."
        },
        "commix.NVIDIA_MODEL": {
          "type": "string",
          "default": "meta/llama-3.2-3b-instruct",
          "description": "Select the NVIDIA-hosted model for AI generation, or run 'Show Available NVIDIA Models' to fetch the latest available models.",
          "enum": [
            "meta/llama-3.2-3b-instruct",
            "meta/llama-3.3-70b-instruct",
            "google/gemma-2-2b-it",
            "google/gemma-3-4b-it",
            "google/gemma-3-12b-it",
            "google/gemma-4-31b-it",
            "microsoft/phi-4-mini-instruct",
            "deepseek-ai/deepseek-v4-flash",
            "deepseek-ai/deepseek-v4-pro",
            "nvidia/llama-3.1-nemotron-70b-instruct"
          ],
          "enumDescriptions": [
            "LLaMA 3.2 3B — Next-generation fast, light, free, and efficient model; excellent for general tasks.",
            "LLaMA 3.3 70B — State-of-the-art open model, excellent reasoning and coding capabilities. Free, but slower.",
            "Gemma 2 2B — Lightweight and highly efficient Gemma 2 model. Fast and free.",
            "Gemma 3 4B — Highly efficient next-generation Gemma 3 model. Fast and free.",
            "Gemma 3 12B — Mid-size next-generation Gemma 3 model with strong reasoning. Fast and free.",
            "Gemma 4 31B — Powerful next-generation Gemma 4 model with advanced reasoning capabilities. Free.",
            "Phi-4 Mini — Compact Microsoft Phi-4 model with strong logical reasoning. Fast and free.",
            "DeepSeek V4 Flash — Extremely fast, efficient model from DeepSeek. Free.",
            "DeepSeek V4 Pro — High-performance model from DeepSeek with deep reasoning capabilities. Free.",
            "NVIDIA Nemotron 70B — State-of-the-art NVIDIA model, highly optimized for helpfulness and coding. Free."
          ]
        },
        "commix.GROQ_API_KEY": {
          "type": "string",
          "default": "",
          "description": "Groq API Key"
        },
        "commix.GROQ_MODEL": {
          "type": "string",
          "default": "llama3-70b-8192",
          "description": "Groq Model to use (e.g., llama3-70b-8192, mixtral-8x7b-32768)"
        },
        "commix.OLLAMA_BASE_URL": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for Ollama (e.g., http://localhost:11434)"
        },
        "commix.OLLAMA_MODEL": {
          "type": "string",
          "default": "llama3",
          "description": "Ollama Model to use (e.g., llama3, mistral, phi)"
        }
      },
      "title": "CommiX"
    },
    "menus": {
      "scm/title": [
        {
          "command": "extension.commix",
          "group": "navigation"
        },
        {
          "command": "commix.preCommitDoc",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "commix.aiEdit",
          "group": "commix-group@1",
          "when": "editorHasSelection"
        },
        {
          "command": "commix.aiExplain",
          "group": "commix-group@2",
          "when": "editorHasSelection"
        },
        {
          "command": "commix.aiConvert",
          "group": "commix-group@3",
          "when": "editorHasSelection"
        },
        {
          "command": "commix.aiDoc",
          "group": "commix-group@4",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commix-sidebar",
          "title": "CommiX",
          "icon": "assets/images/icon.svg"
        }
      ]
    },
    "views": {
      "commix-sidebar": [
        {
          "type": "webview",
          "id": "commix.sidebarView",
          "icon": "assets/images/icon.svg",
          "name": "CommiX"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "publish": "npx @vscode/vsce publish --no-dependencies",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run build",
    "watch": "webpack --watch",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.77.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "webpack": "^5.76.3",
    "webpack-cli": "^5.0.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "fs-extra": "^11.0.4",
    "openai": "^4.14.2",
    "simple-git": "^3.17.0"
  },
  "resolutions": {
    "@types/node": "16.x"
  },
  "license": "MIT"
}
