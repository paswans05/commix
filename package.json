{
  "name": "commix",
  "displayName": "CommiX",
  "description": "AI-powered commit message generator & coding assistant. AI Edit, Refactor, Explain, and Convert tools, featuring CodeLens, Inline Suggestions, and Diff-based Previews — powered by OpenAI, Gemini, and NVIDIA.",
  "version": "6.1.1",
  "engines": {
    "node": ">=16",
    "vscode": "^1.106.2"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "AI",
    "OpenAI",
    "Azure",
    "Gemini",
    "DeepSeek",
    "Git",
    "Git Commit",
    "Commit Message",
    "Commit Generator",
    "Conventional Commits",
    "Gitmoji",
    "Commit Assistant",
    "Semantic Commit",
    "Auto Commit",
    "Code Review",
    "CommiX"
  ],
  "publisher": "paswans05",
  "repository": "https://github.com/paswans05/commix.git",
  "icon": "assets/images/logo.png",
  "activationEvents": [
    "onCommand:commix"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.commix",
        "icon": {
          "dark": "assets/images/icon.svg",
          "light": "assets/images/icon.svg"
        },
        "title": "CommiX"
      },
      {
        "command": "commix.showAvailableModels",
        "title": "Show Available OpenAI Models"
      },
      {
        "command": "commix.aiEdit",
        "title": "CommiX: $(edit) AI Edit / Refactor"
      },
      {
        "command": "commix.aiExplain",
        "title": "CommiX: $(output) Explain Code"
      },
      {
        "command": "commix.aiConvert",
        "title": "CommiX: $(sync) Convert Code"
      },
      {
        "command": "commix.aiSnippet",
        "title": "CommiX: $(code) Generate Snippet"
      },
      {
        "command": "commix.aiTest",
        "title": "CommiX: $(beaker) Generate Test"
      },
      {
        "command": "commix.aiDoc",
        "title": "CommiX: $(book) Generate Documentation"
      },
      {
        "command": "commix.aiWorkflow",
        "title": "CommiX: $(list-ordered) Run AI Workflow"
      },
      {
        "command": "commix.saveTemplate",
        "title": "CommiX: $(save) Save as Template"
      },
      {
        "command": "commix.insertTemplate",
        "title": "CommiX: $(layout) Insert Template"
      },
      {
        "command": "commix.preCommitDoc",
        "title": "Doc Generator",
        "icon": {
          "dark": "assets/images/logo-doc.svg",
          "light": "assets/images/logo-doc.svg"
        }
      }
    ],
    "configuration": {
      "properties": {
        "commix.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable CodeLens (AI Edit/Explain icons above functions)"
        },
        "commix.AI_LANGUAGE": {
          "default": "English",
          "description": "Commit message language",
          "enum": [
            "Japanese",
            "Korean",
            "Czech",
            "German",
            "French",
            "Italian",
            "Dutch",
            "Portuguese",
            "Vietnamese",
            "English",
            "Spanish",
            "Swedish",
            "Russian",
            "Bahasa",
            "Polish",
            "Turkish",
            "Thai",
            "Hindi"
          ],
          "enumDescriptions": [
            "にほんご",
            "한국어",
            "česky",
            "Deutsch",
            "française",
            "italiano",
            "Nederlands",
            "português",
            "tiếng Việt",
            "english",
            "español",
            "Svenska",
            "русский",
            "bahasa",
            "Polski",
            "Turkish",
            "ไทย",
            "हिन्दी"
          ],
          "type": "string"
        },
        "commix.API_VERSION": {
          "default": "",
          "description": "API VERSION",
          "type": "string"
        },
        "commix.OPENAI_API_KEY": {
          "default": "",
          "description": "OpenAI API Key",
          "type": "string"
        },
        "commix.OPENAI_BASE_URL": {
          "default": "",
          "description": "OpenAI BASE URL",
          "type": "string"
        },
        "commix.OPENAI_MODEL": {
          "default": "gpt-4o",
          "description": "OpenAI MODEL, you can select a model from the list by running the 'Show Available OpenAI Models' command",
          "type": "string"
        },
        "commix.PROMPT_SNIPPET": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Snippet Generator"
        },
        "commix.PROMPT_TEST": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Test Generator"
        },
        "commix.PROMPT_DOC": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for AI Documentation Builder"
        },
        "commix.SYSTEM_PROMPT": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for generating commit messages"
        },
        "commix.OPENAI_TEMPERATURE": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "OpenAI temperature setting (0-2). Higher values make output more random, lower values more deterministic."
        },
        "commix.AI_PROVIDER": {
          "type": "string",
          "default": "openai",
          "description": "AI Provider to use (OpenAI , Gemini and NVIDIA)",
          "enum": [
            "openai",
            "gemini",
            "nvidia",
            "groq",
            "ollama"
          ]
        },
        "commix.GEMINI_API_KEY": {
          "type": "string",
          "default": "",
          "description": "Gemini API Key"
        },
        "commix.GEMINI_MODEL": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Gemini Model to use",
          "enum": [
            "gemini-2.5-flash",
            "gemini-2.5-pro",
            "gemini-2.0-flash",
            "gemini-3-flash",
            "gemini-3-pro",
            "gemini-3-flash-preview",
            "gemini-1.5-flash-latest"
          ],
          "enumDescriptions": [
            "Gemini 2.5 Flash (Current stable fast model)",
            "Gemini 2.5 Pro (Current stable high-intelligence model)",
            "Gemini 2.0 Flash (Stable 2.0 series)",
            "Gemini 3 Flash (New fast model)",
            "Gemini 3 Pro (New high-intelligence model)",
            "Gemini 3 Flash Preview (Next-gen preview)",
            "Gemini 1.5 Flash Latest (Latest 1.5 series)"
          ]
        },
        "commix.GEMINI_TEMPERATURE": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Gemini temperature setting (0-2). Controls randomness."
        },
        "commix.NVIDIA_API_KEY": {
          "type": "string",
          "default": "",
          "description": "NVIDIA API Key. Get your key from: https://build.nvidia.com → Sign in → API Keys → Create Key."
        },
        "commix.NVIDIA_MODEL": {
          "type": "string",
          "default": "meta/llama-3.1-70b-instruct",
          "description": "Select the NVIDIA-hosted model for AI generation",
          "enum": [
            "deepseek-ai/deepseek-v4-flash",
            "meta/llama-3.1-70b-instruct",
            "meta/llama-3.1-8b-instruct",
            "meta/llama-3.3-70b-instruct",
            "meta/llama-4-maverick-17b-128e-instruct",
            "microsoft/phi-4-mini-instruct",
            "minimaxai/minimax-m2.5",
            "mistralai/mistral-nemotron",
            "mistralai/mistral-small-4-119b-2603",
            "moonshotai/kimi-k2-instruct",
            "moonshotai/kimi-k2-instruct-0905",
            "nvidia/nemotron-3-nano-30b-a3b",
            "nvidia/nemotron-3-super-120b-a12b",
            "nvidia/nemotron-mini-4b-instruct",
            "nvidia/nemotron-nano-12b-v2-vl",
            "openai/gpt-oss-120b",
            "openai/gpt-oss-20b",
            "qwen/qwen2.5-coder-32b-instruct",
            "qwen/qwen3-coder-480b-a35b-instruct",
            "qwen/qwen3-next-80b-a3b-instruct",
            "qwen/qwen3.5-122b-a10b",
            "stepfun-ai/step-3.5-flash"
          ],
          "enumDescriptions": [
            "DeepSeek V4 Flash — Fast DeepSeek chat model.",
            "LLaMA 3.1 70B — Best quality, strong reasoning, ideal for coding + conversation.",
            "LLaMA 3.1 8B — Fast, light, cheaper; great for general tasks.",
            "LLaMA 3.3 70B — Updated high-quality Llama chat model.",
            "LLaMA 4 Maverick 17B 128E — General-purpose multimodal chat model.",
            "Phi-4 Mini — Ultra-fast and cost-efficient model for lightweight tasks.",
            "MiniMax M2.5 — Coding, reasoning, and office-task model.",
            "Mistral Nemotron — Agentic coding, instruction following, and function-calling model.",
            "Mistral Small 4 119B — Instruct, reasoning, and coding model.",
            "Kimi K2 Instruct — MoE model for reasoning, coding, and agentic tasks.",
            "Kimi K2 Instruct 0905 — Longer-context Kimi K2 model.",
            "Nemotron 3 Nano 30B A3B — Efficient NVIDIA MoE model for coding and reasoning.",
            "Nemotron 3 Super 120B A12B — High-capacity NVIDIA MoE model for coding and planning.",
            "Nemotron Mini 4B — Fast NVIDIA-hosted chat model for lightweight tasks.",
            "Nemotron Nano 12B v2 VL — Vision-language chat model that also supports text prompts.",
            "GPT OSS 120B — High-capacity text-only MoE reasoning model.",
            "GPT OSS 20B — Efficient text-only MoE reasoning model.",
            "Qwen 2.5 Coder 32B — Strong code generation and reasoning.",
            "Qwen 3 Coder 480B — High-capacity code generation model.",
            "Qwen 3 Next 80B A3B — Long-context instruction model.",
            "Qwen 3.5 122B A10B — Coding, reasoning, and agent-ready chat model.",
            "Step 3.5 Flash — Fast sparse MoE reasoning model."
          ]
        },
        "commix.GROQ_API_KEY": {
          "type": "string",
          "default": "",
          "description": "Groq API Key"
        },
        "commix.GROQ_MODEL": {
          "type": "string",
          "default": "llama3-70b-8192",
          "description": "Groq Model to use (e.g., llama3-70b-8192, mixtral-8x7b-32768)"
        },
        "commix.OLLAMA_BASE_URL": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for Ollama (e.g., http://localhost:11434)"
        },
        "commix.OLLAMA_MODEL": {
          "type": "string",
          "default": "llama3",
          "description": "Ollama Model to use (e.g., llama3, mistral, phi)"
        }
      },
      "title": "CommiX"
    },
    "menus": {
      "scm/title": [
        {
          "command": "extension.commix",
          "group": "navigation"
        },
        {
          "command": "commix.preCommitDoc",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "commix.aiEdit",
          "group": "commix-group@1",
          "when": "editorHasSelection"
        },
        {
          "command": "commix.aiExplain",
          "group": "commix-group@2",
          "when": "editorHasSelection"
        },
        {
          "command": "commix.aiConvert",
          "group": "commix-group@3",
          "when": "editorHasSelection"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commix-sidebar",
          "title": "CommiX",
          "icon": "assets/images/icon.svg"
        }
      ]
    },
    "views": {
      "commix-sidebar": [
        {
          "type": "webview",
          "id": "commix.sidebarView",
          "icon": "assets/images/icon.svg",
          "name": "CommiX"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "webpack --mode production --devtool hidden-source-map",
    "compile": "webpack",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "publish": "vsce publish --no-dependencies",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run build",
    "watch": "webpack --watch",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.77.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.5",
    "webpack": "^5.76.3",
    "webpack-cli": "^5.0.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "fs-extra": "^11.0.4",
    "openai": "^4.14.2",
    "simple-git": "^3.17.0"
  },
  "resolutions": {
    "@types/node": "16.x"
  },
  "license": "MIT"
}
